// ShopBook - Prisma Schema
// Database: MySQL / MariaDB

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

// ============================================================
// MODELS
// ============================================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  avatar    String?
  phone     String?
  address   String?  @db.Text
  vatType     String?  @map("vat_type") // PERSONAL or COMPANY
  vatName     String?  @map("vat_name")
  vatTaxCode  String?  @map("vat_tax_code")
  vatAddress  String?  @db.Text @map("vat_address")
  vatEmail    String?  @map("vat_email")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  orders    Order[]
  reviews   Review[]
  cartItems CartItem[]
  addresses Address[]
  notifications Notification[]
  wishlist  WishlistItem[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  image       String?
  icon        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  books Book[]

  @@index([slug])
  @@map("categories")
}

model Book {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  author      String
  description String?  @db.LongText
  price       Decimal  @db.Decimal(10, 2)
  salePrice   Decimal? @db.Decimal(10, 2) @map("sale_price")
  isbn        String?  @unique
  publisher   String?
  publishedAt DateTime? @map("published_at")
  pages       Int?
  language    String   @default("Vietnamese")
  stock       Int      @default(0)
  sold        Int      @default(0)
  rating      Float    @default(0)
  ratingCount Int      @default(0) @map("rating_count")
  featured    Boolean  @default(false)
  image       String?
  images      Json?    // Array of image URLs
  categoryId  String   @map("category_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  reviews        Review[]
  cartItems      CartItem[]
  flashSaleItems FlashSaleItem[]
  wishlistedBy   WishlistItem[]

  @@index([slug])
  @@index([categoryId])
  @@index([featured])
  @@index([price])
  @@index([rating])
  @@index([title])
  @@map("books")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @map("order_number")
  userId          String      @map("user_id")
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(10, 2)
  shippingFee     Decimal     @default(0) @db.Decimal(10, 2) @map("shipping_fee")
  total           Decimal     @db.Decimal(10, 2)
  shippingName    String?     @map("shipping_name")
  shippingPhone   String?     @map("shipping_phone")
  shippingAddress String?     @db.Text @map("shipping_address")
  note            String?     @db.Text
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  user       User        @relation(fields: [userId], references: [id])
  items      OrderItem[]
  payment    Payment?

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id       String  @id @default(cuid())
  orderId  String  @map("order_id")
  bookId   String  @map("book_id")
  quantity Int
  price    Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  book  Book  @relation(fields: [bookId], references: [id])

  @@index([orderId])
  @@index([bookId])
  @@map("order_items")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  bookId    String   @map("book_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@index([userId])
  @@map("cart_items")
}

model Review {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  bookId    String   @map("book_id")
  rating    Int      // 1-5
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId])
  @@index([rating])
  @@map("reviews")
}

model Payment {
  id              String   @id @default(cuid())
  orderId         String   @unique @map("order_id")
  stripePaymentId String?  @map("stripe_payment_id")
  method          String   @default("stripe")
  amount          Decimal  @db.Decimal(10, 2)
  status          String   @default("pending") // pending, succeeded, failed
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([stripePaymentId])
  @@map("payments")
}

model FlashSale {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  status    String   @default("ACTIVE") // ACTIVE, DRAFT
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items     FlashSaleItem[]

  @@map("flash_sales")
}

model FlashSaleItem {
  id            String   @id @default(cuid())
  flashSaleId   String   @map("flash_sale_id")
  bookId        String   @map("book_id")
  discountPrice Decimal  @db.Decimal(10, 2) @map("discount_price")

  flashSale FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  book      Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([flashSaleId, bookId])
  @@index([flashSaleId])
  @@index([bookId])
  @@map("flash_sale_items")
}

model Address {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  fullName  String   @map("full_name")
  phone     String
  street    String   @db.Text
  ward      String
  district  String
  city      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") // If null, maybe global notification? Keeping it simple with direct user notifications
  title     String
  content   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  bookId    String   @map("book_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId])
  @@index([bookId])
  @@map("wishlist_items")
}

model Setting {
  key       String   @id
  value     String   @db.LongText
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
